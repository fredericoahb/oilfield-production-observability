{
  "uid": "kpi-api-sli",
  "title": "KPI API SLI",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "tags": [
    "oilfield",
    "observability"
  ],
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "KPI API p95 latency (ms)",
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket{job=\"kpi-service\"}[5m])) by (le)) * 1000",
          "refId": "A",
          "legendFormat": ""
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms"
        },
        "overrides": []
      },
      "options": {}
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "KPI API error rate (5xx)",
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{job=\"kpi-service\",status=~\"5..\"}[5m]))",
          "refId": "A",
          "legendFormat": ""
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        },
        "overrides": []
      },
      "options": {}
    }
  ],
  "time": {
    "from": "now-1h",
    "to": "now"
  }
}